              ],
              "title": "Coverage"
            }
          },
          {
            "name": "voltage_level",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "enum": [
                    "Niederspannung",
                    "Mittelspannung",
